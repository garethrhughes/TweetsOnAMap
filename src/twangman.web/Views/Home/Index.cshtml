@{
    Layout = null;
}

<!DOCTYPE html>

<html>
    <head>
    <title>@@TweetsOnAMap</title>
    <meta name="viewport" content="initial-scale=1.0, user-scalable=no" />
   <link href="/css/bootstrap.css" type="text/css" rel="stylesheet"/>
   
    
        <style type="text/css">
            * { padding: 0; margin: 0; }
         html { height: 100% }
            body { height: 100%; margin: 0; padding: 0 }
            
            #map-canvas img {
              max-width: none;
            }
            
            .navbar 
            {
                position: fixed;
                bottom: 10px;
                left: 2%;
                width: 96%;
            }
            
            .navbar p 
            {
              margin: 0;
              line-height: 40px; 
            }
            
            .alert-info.top 
            {
              position: fixed;
              top: 20px;
              left: 50%;
              margin-left: -150px;
              width: 300px;
            }
            
            .media-list.right
            {
              position:absolute;
              right: 2%;
              bottom: 80px;
              width: 300px;
            }
            
                  .media-list.left
            {
              position:absolute;
              left: 2%;
              bottom: 80px;
              width: 300px;
            }
            .media.navbar-inner
            {
              padding: 10px;
            }
            
            #logo 
            {
              left: 1%;
              position: fixed;
              top: 10px;
            }
            
            .info-window 
            {
              border-radius: 5px;
            }
            
            .infobox-wrapper {
                display:none;
            }
            .infobox-inner {
                border:2px solid black;
                margin-top: 8px;
                background:#333;
                color:#FFF;
                font-family:Arial, Helvetica, sans-serif;
                font-size:12px;
                padding: .5em 1em;
                -webkit-border-radius: 2px;
                -moz-border-radius: 2px;
                border-radius: 2px;
                text-shadow:0 -1px #000000;
                -webkit-box-shadow: 0 0  8px #000;
                box-shadow: 0 0 8px #000;
                overflow: auto;
            }

            .infoBox > img 
            {
              left: -20px;
            }

        </style>

</head>
<body>
    <div>
        <div id="map-canvas"></div>

        <img id="logo" src="http://asset.9msn.com.au/img/000/000/180/419/ninemsn_logo.gif" />
        <div class="alert alert-info top">
          Welcome to <a href="">@@TweetsOnAMap</a><button class="close pull-right">&times;</button>
        </div>

        <ul class="media-list left">
  
        </ul>

        <ul class="media-list right">
     
        </ul>


        <div class="navbar">
          <div class="navbar-inner">
            <p class="pull-left">Active Viewers: <span id="data-loc" class="badge badge-success">0</span> Total Tweets: <span class="badge badge-success" id="total-tweets">0</span></p>
            <p class="pull-right"><a href="#">Sydney killer 'can't recall' fatal minutes</a></p>
          </div>
        </div>

        <script src="/scripts/jquery-1.9.1.js"></script>
        <script src="/scripts/jquery.signalR-1.0.1.js"></script>
        <script type="text/javascript" src="/scripts/bootstrap.min.js"></script>
        <script src="/signalr/hubs"></script>
        <script src="/scripts/SignalR.TwitterTicker.js"></script>
        
        <script type="text/javascript"
          src="https://maps.googleapis.com/maps/api/js?key=AIzaSyA4OLXZzFfoqBbhseHYT1CMm5_wKegdGzE&sensor=false">
        </script>

        <script type="text/javascript" src="http://google-maps-utility-library-v3.googlecode.com/svn/trunk/infobox/src/infobox.js"></script>

        <script type="text/javascript">
            (function() {
                function initialize() {
                    var mapOptions = {
                        center: new google.maps.LatLng(-34.397, 150.644),
                        zoom: 8,
                        mapTypeId: google.maps.MapTypeId.ROADMAP,
                        streetViewControl: false,
                        disableDefaultUI: true
                    };
                    window.map = new google.maps.Map(document.getElementById("map-canvas"), mapOptions);
                }

                $('#map-canvas').css('height', $(window).height());
                google.maps.event.addDomListener(window, 'load', initialize);
            })();
        </script>
    </div>
</body>
</html>
