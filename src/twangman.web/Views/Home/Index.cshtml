@{
    Layout = null;
}

<!DOCTYPE html>

<html>
    <head>
    <title>Maps Maps Maps!</title>
    <meta name="viewport" content="initial-scale=1.0, user-scalable=no" />
        <style type="text/css">
            * { padding: 0; margin: 0; }
         html { height: 100% }
            body { height: 100%; margin: 0; padding: 0 }
            #data-loc {
                position: fixed;
                bottom: 20px;
                left: 20px;
                background-color: white;
                height: 50px;
                width: 100px;
            }
            
            #postcode {
                position: fixed;
                bottom: 20px;
                right: 20px;
                background-color: white;
                height: 50px;
                width: 100px;
            }
        </style>

</head>
<body>
    <div>
        <div id="map-canvas"></div>
        
        <div id="data-loc"></div>
        <div id="postcode"></div>

        <script src="/scripts/jquery-1.9.1.js"></script>
        <script src="/scripts/jquery.signalR-1.0.1.js"></script>
        <script src="/signalr/hubs"></script>
        <script src="/scripts/SignalR.TwitterTicker.js"></script>
        
        <script type="text/javascript"
          src="https://maps.googleapis.com/maps/api/js?key=AIzaSyA4OLXZzFfoqBbhseHYT1CMm5_wKegdGzE&sensor=false">
        </script>
        <script type="text/javascript">
            (function() {
                function initialize() {
                    var mapOptions = {
                        center: new google.maps.LatLng(-34.397, 150.644),
                        zoom: 8,
                        mapTypeId: google.maps.MapTypeId.ROADMAP
                    };
                    window.map = new google.maps.Map(document.getElementById("map-canvas"), mapOptions);
                }

                $('#map-canvas').css('height', $(window).height());
                google.maps.event.addDomListener(window, 'load', initialize);
            })();
        </script>
    </div>
</body>
</html>
