@{
    Layout = null;
}

<!DOCTYPE html>

<html>
    <head>
    <title>Maps Maps Maps!</title>
    <meta name="viewport" content="initial-scale=1.0, user-scalable=no" />
   <link href="/css/bootstrap.css" type="text/css" rel="stylesheet"/>       
        <style type="text/css">
            * { padding: 0; margin: 0; }
         html { height: 100% }
            body { height: 100%; margin: 0; padding: 0 }
            
            #map-canvas img {
              max-width: none;
            }
            
            .navbar 
            {
                position: fixed;
                bottom: 10px;
                left: 2%;
                width: 96%;
            }
            
            .navbar p 
            {
              margin: 0;
              line-height: 40px; 
            }
            
            .alert-info.top 
            {
              position: fixed;
              top: 20px;
              left: 50%;
              margin-left: -150px;
              width: 300px;
            }
            
            .media-list 
            {
              position:absolute;
              right: 2%;
              bottom: 80px;
              width: 300px;
            }
            
            .media.navbar-inner
            {
              padding: 10px;
            }
            
            #logo 
            {
              left: 1%;
              position: fixed;
              top: 10px;
            }
        </style>

</head>
<body>
    <div>
        <div id="map-canvas"></div>

        <img id="logo" src="http://asset.9msn.com.au/img/000/000/180/419/ninemsn_logo.gif" />
        <div class="alert alert-info top">
          Welcome to Maps! <button class="close pull-right">&times;</button>
        </div>

        <ul class="media-list">
          <li class="media navbar-inner">
            <a class="pull-left" href="#">
              <img class="media-object" src="http://placehold.it/64x64">
            </a>
            <div class="media-body">
              Stuff and things happened today
            </div>
          </li>          <li class="media navbar-inner">
            <a class="pull-left" href="#">
              <img class="media-object" src="http://placehold.it/64x64">
            </a>
            <div class="media-body">
              Stuff and things happened today
            </div>
          </li>          <li class="media navbar-inner">
            <a class="pull-left" href="#">
              <img class="media-object" src="http://placehold.it/64x64">
            </a>
            <div class="media-body">
              Stuff and things happened today
            </div>
          </li>

          <li class="media navbar-inner">
            <a class="pull-left" href="#">
              <img class="media-object" src="http://placehold.it/64x64">
            </a>
            <div class="media-body">
              Stuff and things happened today
            </div>
          </li>
        </ul>


        <div class="navbar">
          <div class="navbar-inner">
            <p class="pull-left">Active Viewers: <span id="data-loc"></span></p>
            <p class="pull-right">Total Tweets: <span id="total-tweets"></span></p>
          </div>
        </div>

        <script src="/scripts/jquery-1.9.1.js"></script>
        <script src="/scripts/jquery.signalR-1.0.1.js"></script>
        <script type="text/javascript" src="/scripts/bootstrap.min.js"></script>
        <script src="/signalr/hubs"></script>
        <script src="/scripts/SignalR.TwitterTicker.js"></script>
        
        <script type="text/javascript"
          src="https://maps.googleapis.com/maps/api/js?key=AIzaSyA4OLXZzFfoqBbhseHYT1CMm5_wKegdGzE&sensor=false">
        </script>
        <script type="text/javascript">
            (function() {
                function initialize() {
                    var mapOptions = {
                        center: new google.maps.LatLng(-34.397, 150.644),
                        zoom: 8,
                        mapTypeId: google.maps.MapTypeId.ROADMAP,
                        streetViewControl: false,
                        disableDefaultUI: true
                    };
                    window.map = new google.maps.Map(document.getElementById("map-canvas"), mapOptions);
                }

                $('#map-canvas').css('height', $(window).height());
                google.maps.event.addDomListener(window, 'load', initialize);
            })();
        </script>
    </div>
</body>
</html>
